#!/bin/sh
# S99keen-manager — Entware init script for the keen-manager daemon.
#
# Entware-style (procd-less) SysV init script. Runs the foreground daemon
# `keen-manager daemon` in the background, tracks it with a PID file, and
# appends its output to a log file. Installed to /opt/etc/init.d/ and invoked
# by Entware's rc at boot (S99 = late, after network/opkg services).
#
# Usage: S99keen-manager {start|stop|restart|status|check}

# --- Configuration ----------------------------------------------------------
NAME="keen-manager"
BIN="/opt/bin/keen-manager"
ARGS="daemon"
RUN_DIR="/opt/var/run"
PIDFILE="${RUN_DIR}/keen-manager.pid"
LOG_DIR="/opt/var/log"
LOGFILE="${LOG_DIR}/keen-manager.log"

# --- Helpers ----------------------------------------------------------------

# is_running: succeed (0) if a live process matches the recorded PID.
is_running() {
	[ -f "$PIDFILE" ] || return 1
	_pid=$(cat "$PIDFILE" 2>/dev/null)
	[ -n "$_pid" ] || return 1
	# kill -0 tests for existence without sending a signal.
	if kill -0 "$_pid" 2>/dev/null; then
		return 0
	fi
	# Stale PID file: process is gone.
	return 1
}

running_pid() {
	cat "$PIDFILE" 2>/dev/null
}

# --- Actions ----------------------------------------------------------------

start() {
	if is_running; then
		echo "$NAME already running (pid $(running_pid))"
		return 0
	fi

	if [ ! -x "$BIN" ]; then
		echo "$NAME: binary not found or not executable at $BIN" >&2
		echo "$NAME: (re)install with the keen-manager installer" >&2
		return 1
	fi

	# Ensure writable dirs exist (RUN_DIR/LOG_DIR live under /opt).
	mkdir -p "$RUN_DIR" "$LOG_DIR" 2>/dev/null

	echo "Starting $NAME ..."
	# Background the foreground daemon; record its PID. setsid detaches it from
	# the controlling terminal when available (busybox may not ship it).
	if command -v setsid >/dev/null 2>&1; then
		setsid "$BIN" $ARGS >>"$LOGFILE" 2>&1 &
	else
		"$BIN" $ARGS >>"$LOGFILE" 2>&1 &
	fi
	echo $! > "$PIDFILE"

	# Give it a moment, then confirm it stayed up.
	sleep 1
	if is_running; then
		echo "$NAME started (pid $(running_pid)); logging to $LOGFILE"
		return 0
	fi
	echo "$NAME failed to start; see $LOGFILE" >&2
	rm -f "$PIDFILE"
	return 1
}

stop() {
	if ! is_running; then
		echo "$NAME not running"
		rm -f "$PIDFILE"
		return 0
	fi

	_pid=$(running_pid)
	echo "Stopping $NAME (pid $_pid) ..."
	kill "$_pid" 2>/dev/null

	# Wait up to ~10s for a graceful exit, then force-kill.
	_i=0
	while [ "$_i" -lt 10 ]; do
		if ! kill -0 "$_pid" 2>/dev/null; then
			break
		fi
		sleep 1
		_i=$((_i + 1))
	done
	if kill -0 "$_pid" 2>/dev/null; then
		echo "$NAME did not stop gracefully; sending SIGKILL"
		kill -9 "$_pid" 2>/dev/null
	fi

	rm -f "$PIDFILE"
	echo "$NAME stopped"
	return 0
}

restart() {
	stop
	sleep 1
	start
}

status() {
	if is_running; then
		echo "$NAME is running (pid $(running_pid))"
		return 0
	fi
	echo "$NAME is stopped"
	return 1
}

# check: start only if not already running (used by watchdog/cron re-checks).
check() {
	if is_running; then
		return 0
	fi
	echo "$NAME not running; starting"
	start
}

# --- Dispatch ---------------------------------------------------------------
case "$1" in
	start)   start ;;
	stop)    stop ;;
	restart) restart ;;
	status)  status ;;
	check)   check ;;
	*)
		echo "Usage: $0 {start|stop|restart|status|check}" >&2
		exit 1
		;;
esac

exit $?
